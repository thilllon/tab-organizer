{
  "git": {
    "requireBranch": "main",
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "hooks": {
    "before:bump": "tsx scripts/prepare-registration.ts",
    "after:bump": "pnpm build && tsx scripts/zip.ts"
  }
}
