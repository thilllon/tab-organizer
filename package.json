{
  "name": "tab-organizer",
  "displayName": "Tab Organizer",
  "description": "Chrome extension that sorts and organizes your browser tabs.",
  "version": "6.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/thilllon/tab-organizer.git"
  },
  "keywords": [
    "chrome-extension",
    "tab-organizer",
    "tab-sort"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write . && prettier --write '**/*.{md,mdx}' && mise format",
    "test": "vitest run",
    "release": "release-it"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@crxjs/vite-plugin": "^2.4.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/archiver": "^7.0.0",
    "@types/chrome": "^0.1.38",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "archiver": "^7.0.1",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "shadcn": "^4.1.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
